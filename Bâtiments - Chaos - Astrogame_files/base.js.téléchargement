    "SxD",
    "SpD",
    "OD",
    "ND",
    "V",
    "UV",
    "DV",
    "TV",
    "QV",
    "QQV",
    "SxV",
    "SpV",
    "OV",
    "NV",
    "C",
    "UC",
    "DC",
    "TC",
    "QC",
    "QqC",
    "SxC",
    "SpC",
    "OC",
    "NC",
  ];
  const negative = typeof value === "string" ? value.startsWith("-") : value < 0;
  let n = BigInt(negative ? String(value).replace(/[^0-9]/g, "") : value);
  if (n < 1000n) return (negative ? "-" : "") + n.toString();
  let key = 0;
  let rem = 0n;
  while (n >= 1000n && key < units.length - 1) {
    rem = n % 1000n;
    n /= 1000n;
    key++;
  }
  let txt = n.toString();
  if (rem !== 0n && n < 100n) {
    let decimal = Number(rem) / 1000;
    let decimalStr = decimal.toFixed(1).slice(2);
    if (decimalStr.replace(/0+$/, "") !== "") {
      txt += "," + decimalStr.replace(/0+$/, "");
    }
    return (negative ? "-" : "") + txt + "\u00A0" + units[key];
  }
  if (rem >= 500n) {
    n += 1n;
    txt = n.toString();
  }
  return (negative ? "-" : "") + txt + "\u00A0" + units[key];
}

function removeE(Number) {
  Number = String(Number);

  if (Number.search(/e\+/) == -1) {
    return Number;
  }

  var e = parseInt(Number.replace(/\S+.?e\+/g, ""));

  if (isNaN(e) || e == 0) {
    return Number;
  } else if ($.browser.webkit || $.browser.msie) {
    return parseFloat(Number).toPrecision(Math.min(e + 1, 21));
  } else {
    return parseFloat(Number).toPrecision(e + 1);
  }
}

function numberOnly(e) {
  var whichCode = window.Event ? e.which : e.keyCode;

  if (whichCode == 13) {
    return true;
  }

  if (whichCode > 57) {
