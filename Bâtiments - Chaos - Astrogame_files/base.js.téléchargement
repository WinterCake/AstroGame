function formatInput($input) {
  const origVal = $input.val();
  const origCursor = $input[0].selectionStart;

  const digitsLeft = origVal.slice(0, origCursor).replace(/\D/g, "").length;

  let rawUnformatted = origVal.replace(/\D/g, "");

  let match = rawUnformatted.match(/^0+/);
  let leadingZeroCount = match ? match[0].length : 0;

  let unformatted;
  if (rawUnformatted.length > 1 && origCursor > leadingZeroCount && !/^0+$/.test(rawUnformatted)) {
    unformatted = rawUnformatted.replace(/^0+/, "");
  } else {
    unformatted = rawUnformatted;
  }

  if (unformatted === "") {
    $input.val("0");
    $input[0].setSelectionRange(1, 1);
    return;
  }

  const formatted = unformatted.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
  $input.val(formatted);

  if (digitsLeft === 0) {
    $input[0].setSelectionRange(0, 0);
    return;
  }

  let newCursorPos = formatted.length;
  let digitCount = 0;
  for (let i = 0; i < formatted.length; i++) {
    if (/\d/.test(formatted[i])) {
      digitCount++;
      if (digitCount === digitsLeft) {
        newCursorPos = i + 1;
        break;
      }
    }
  }
  $input[0].setSelectionRange(newCursorPos, newCursorPos);
}

function getCleanInput($input) {
  const val = $input.val();
  return val.replace(/\./g, "").replace(/,/g, ".").replace(/\s/g, "");
}

function showNotification(message, duration = 3000, type = "") {
  const container = document.getElementById("notification-container");
  if (!container) return;

  const toast = document.createElement("div");
  toast.className = `notification-toast ${type}`;
  toast.style.setProperty("--delay", `${duration}ms`);
  toast.textContent = message;

  container.appendChild(toast);

  setTimeout(() => {
    toast.remove();
  }, duration + 1000);
}

function showModalConfirm(title = null, content, onConfirm, onCancel = null) {
  const overlay = document.getElementById("modal-overlay");
  if (!overlay) return console.error("modal-overlay bulunamadı");

  overlay.classList.remove("hidden");
  overlay.innerHTML = "";

  const modalBox = document.createElement("div");
  modalBox.className = "modal-box";

  if (title) {
    const titleEl = document.createElement("div");
    titleEl.className = "modal-title";
    titleEl.textContent = title;
    modalBox.appendChild(titleEl);
  }

  const messageEl = document.createElement("div");
  messageEl.className = "modal-message";

  if (typeof content === "string") {
    if (content.trim().startsWith("<")) {
      messageEl.innerHTML = content;
    } else {
      messageEl.textContent = content;
    }
  } else if (content instanceof HTMLElement) {
    messageEl.appendChild(content);
  }

  const actions = document.createElement("div");
  actions.className = "modal-actions";

  const confirmBtn = document.createElement("button");
  confirmBtn.className = "button md success";
  confirmBtn.textContent = modalLang.modalConfirm;

  const cancelBtn = document.createElement("button");
  cancelBtn.className = "button md danger";
  cancelBtn.textContent = modalLang.modalCancel;

  actions.appendChild(confirmBtn);
  actions.appendChild(cancelBtn);

  modalBox.appendChild(messageEl);
  modalBox.appendChild(actions);
  overlay.appendChild(modalBox);

  const cleanup = () => {
    overlay.classList.add("hidden");
    overlay.innerHTML = "";
  };

  confirmBtn.addEventListener("click", () => {
    cleanup();
    if (typeof onConfirm === "function") onConfirm();
  });

  cancelBtn.addEventListener("click", () => {
    cleanup();
    if (typeof onCancel === "function") onCancel();
  });
}

