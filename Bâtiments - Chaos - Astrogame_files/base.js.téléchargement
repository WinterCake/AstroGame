function statusChecker(force) {
  force = force || false;

  $.get(
    siteUrl + "game/statusCheck",
    function (data) {
      if (data.redirect !== false) {
        redirect(data.redirect);
      } else {
        if (typeof data.token !== "undefined" && data.status == true) {
          var reconnect = false;

          if (data.token != SysSocket.token) {
            SysSocket.setToken(data.token);
          }

          const socket = SysSocket.socket;
          const isClosed = typeof socket?.isClosed === "function" ? socket.isClosed() : false;
          const isDraining = typeof socket?.isDraining === "function" ? socket.isDraining() : false;
          const hasHealthyConnection = SysSocket.ready && socket && !isClosed && !isDraining;

          if (force || !hasHealthyConnection) {
            if (socket) {
              try {
                socket.close();
              } catch (closeErr) {
                SysSocket.debug && console.warn("[SysSocket] Close failed before reconnect:", closeErr?.message || closeErr);
              }
            }

            SysSocket.socket = null;
            SysSocket.ready = false;
            SysSocket.connect(true);
            reconnect = true;
          }

          if (reconnect) {
            SysSocket.readyCheck(function () {
              var userdataKey = "userdata:" + loggedInId;
              SysSocket.unSubscribe(userdataKey);
              SysSocket.unsetQueue(userdataKey);
              SysSocket.subscribe(userdataKey);
              SysSocket.setQueue(userdataKey);

              var fleetsKey = "fleets:" + loggedInId;
              SysSocket.unSubscribe(fleetsKey);
              SysSocket.unsetQueue(fleetsKey);
              SysSocket.subscribe(fleetsKey);
              SysSocket.setQueue(fleetsKey);

              var onlineKey = "uni" + loggedInUId + ":online";
              SysSocket.unSubscribe(onlineKey);
              SysSocket.unsetQueue(onlineKey);
              SysSocket.subscribe(onlineKey);
              SysSocket.setQueue(onlineKey);

              initSocketActions();
            });
          }
        }
      }
    },
    "json"
  );
}

