function getFormatedDate(timestamp, format) {
  // Zamanı en yakın saniyeye yuvarla
  var roundedTimestamp = Math.round((timestamp + ServerTimezoneOffset * 1000) / 1000) * 1000;
  var currTime = new Date(roundedTimestamp);

  str = format;
  str = str.replace("[d]", dezInt(currTime.getDate(), 2));
  str = str.replace("[D]", days[currTime.getDay()]);
  str = str.replace("[m]", dezInt(currTime.getMonth() + 1, 2));
  str = str.replace("[M]", months[currTime.getMonth()]);
  str = str.replace("[j]", parseInt(currTime.getDate()));
  str = str.replace("[Y]", currTime.getFullYear());
  str = str.replace("[y]", currTime.getFullYear().toString().substr(2, 4));
  str = str.replace("[G]", currTime.getHours());
  str = str.replace("[H]", dezInt(currTime.getHours(), 2));
  str = str.replace("[i]", dezInt(currTime.getMinutes(), 2));
  str = str.replace("[s]", dezInt(currTime.getSeconds(), 2));

  return str;
}

function dezInt(num, size, prefix) {
  prefix = prefix ? prefix : "0";
  var minus = num < 0 ? "-" : "",
    result = prefix == "0" ? minus : "";
  num = Math.abs(parseInt(num, 10));
  size -= ("" + num).length;

  for (var i = 1; i <= size; i++) {
    result += "" + prefix;
  }

  result += (prefix != "0" ? minus : "") + num;

  return result;
}

function timeConverter(UNIX_timestamp) {
  var a = new Date();
  a.setTime(UNIX_timestamp * 1000);
  var year = a.getFullYear();
  var month = months[a.getMonth()];
  var date = a.getDate();
  var hour = dezInt(a.getHours(), 2);
  var min = dezInt(a.getMinutes(), 2);
  var sec = dezInt(a.getSeconds(), 2);
  var time = date + " " + month + " " + year + " " + hour + ":" + min + ":" + sec;

  return time;
}

function getFormatedTime(time) {
  hours = Math.floor(time / 3600);
  timeleft = time % 3600;
  minutes = Math.floor(timeleft / 60);
  timeleft = timeleft % 60;
  seconds = timeleft;

  return dezInt(hours, 2) + ":" + dezInt(minutes, 2) + ":" + dezInt(seconds, 2);
}

function divideLargeNumber(dividend, divisor) {
  let result = "";
  let idx = 0;
  let temp = dividend[idx] - "0";

  while (temp < divisor) {
    temp = temp * 10 + (dividend[++idx] - "0");
  }

  while (dividend.length > idx) {
    result += Math.floor(temp / divisor);
    temp = (temp % divisor) * 10 + (dividend[++idx] - "0");
  }

  if (result.length === 0) {
    return "0";
  }

  return result;
}

function modLargeNumber(dividend, divisor) {
  let mod = 0;
  for (let i = 0; i < dividend.length; i++) {
    mod = (mod * 10 + (dividend[i] - "0")) % divisor;
  }
  return mod;
}

function subtractLargeNumbers(num1, num2) {
  // Öncelikle sayıları karşılaştırarak hangi sayının büyük olduğunu belirleyin
  let negativeResult = false;
  if (num1 === num2) return "0";

  if (num1.length < num2.length || (num1.length === num2.length && num1 < num2)) {
    [num1, num2] = [num2, num1];
    negativeResult = true;
  }

  let carry = 0;
  let result = "";

  while (num1.length < num2.length) num1 = "0" + num1;
  while (num2.length < num1.length) num2 = "0" + num2;

  for (let i = num1.length - 1; i >= 0; i--) {
    let digit1 = parseInt(num1[i]);
    let digit2 = parseInt(num2[i]) + carry;

    if (digit1 < digit2) {
      digit1 += 10;
      carry = 1;
    } else {
      carry = 0;
    }

    result = digit1 - digit2 + result;
  }

  result = result.replace(/^0+/, ""); // Başı sıfırlardan temizle
  return negativeResult ? "-" + result : result;
}

function secondsToDhms(seconds) {
  const dayInSeconds = 3600 * 24;
  const hourInSeconds = 3600;
  const minuteInSeconds = 60;

  let d = divideLargeNumber(seconds, dayInSeconds);
  seconds = modLargeNumber(seconds, dayInSeconds).toString();

  let h = divideLargeNumber(seconds, hourInSeconds);
  seconds = modLargeNumber(seconds, hourInSeconds).toString();

  let m = divideLargeNumber(seconds, minuteInSeconds);
  let s = modLargeNumber(seconds, minuteInSeconds).toString();

  return (d !== "0" ? d + " " + (d > 1 ? long_days : long_day) + " " : "") + dezInt(h, 2) + ":" + dezInt(m, 2) + ":" + dezInt(s, 2);
}

function GetRestTimeFormat(Secs) {
  var s = Secs;
  var m = 0;
  var h = 0;

  if (s > 59) {
    m = Math.floor(s / 60);
    s = s - m * 60;
  }

  if (m > 59) {
    h = Math.floor(m / 60);
    m = m - h * 60;
  }

  return dezInt(h, 2) + ":" + dezInt(m, 2) + ":" + dezInt(s, 2);
}

