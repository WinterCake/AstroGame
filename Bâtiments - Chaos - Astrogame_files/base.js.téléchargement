function updateResourcesFromAjax(resourcesData) {
  if (!resourcesData) return;
  const resourceIds = [901, 902, 903, 921];

  resourceIds.forEach((resourceId) => {
    if (resourcesData[resourceId] === undefined) return;

    const newValue = resourcesData[resourceId];

    const currentElement = document.getElementById(`current_${resourceId}`);
    if (currentElement) {
      const valueSpan = currentElement.querySelector(".value");
      if (valueSpan) valueSpan.textContent = shortlyNumberBig(newValue);
    }

    const resourceNameElement = document.querySelector(`.resourceName[data-id="${resourceId}"]`);
    if (resourceNameElement) {
      const maxValue = resourceNameElement.getAttribute("data-max");
      if (maxValue !== undefined && resourceId !== 921) {
        const isOverflow = newValue > maxValue;
        resourceNameElement.setAttribute("data-overflow", isOverflow ? "true" : "false");
      }
      const resourceCurrentElement = resourceNameElement.parentElement.querySelector(".resourceCurrent");
      if (resourceCurrentElement) {
        const currentValueSpan = resourceCurrentElement.querySelector(".current");
        if (currentValueSpan) currentValueSpan.textContent = shortlyNumberBig(newValue);
      }
    }

    const mobileCard = document.querySelector(`.resourceCardMobile[data-id="${resourceId}"]`);
    if (mobileCard) {
      const mobileResourceCurrent = mobileCard.querySelector(".resourceCurrent");
      if (mobileResourceCurrent) {
        const maxValue = resourceNameElement ? parseInt(resourceNameElement.getAttribute("data-max")) : null;

        if (!isNaN(maxValue) && newValue > maxValue && resourceId !== 921) {
          mobileResourceCurrent.innerHTML = `<span style="color: var(--danger-500);">${shortlyNumberBig(newValue)}</span>`;
        } else {
          mobileResourceCurrent.textContent = shortlyNumberBig(newValue);
        }
      }
    }

    let tooltipSelector;
    switch (resourceId) {
      case 901:
        tooltipSelector = "#tooltip_metal";
        break;
      case 902:
        tooltipSelector = "#tooltip_crystal";
        break;
      case 903:
        tooltipSelector = "#tooltip_deuterium";
        break;
      case 921:
        tooltipSelector = "#tooltip_darkmatter";
        break;
      default:
        return;
    }

    const tooltipElement = document.querySelector(tooltipSelector);
    if (tooltipElement) tooltipElement.dataset.current = String(newValue);
  });
}

