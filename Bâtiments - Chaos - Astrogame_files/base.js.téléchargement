  decial = key != 0 && number != 0 && number < 100;

  return NumberGetHumanReadable(negate * number, decial) + (key !== 0 ? "&nbsp;" + unit[key] : "");
}

function shortlyNumberBig(value) {
  const units = [
    "",
    "K",
    "M",
    "Mr",
    "T",
    "KaT",
    "KeT",
    "Ss",
    "St",
    "O",
    "N",
    "D",
