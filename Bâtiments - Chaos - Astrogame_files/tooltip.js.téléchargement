$(document).ready(function () {
  initTooltip();
});

function initTooltip() {
 
  if (typeof activeTemplate !== "undefined" && activeTemplate == "rampage") {
    return;
  }

  $(".tooltip").not(".tooltipstered").tooltipster({
    contentAsHTML: true,
    trigger: "ontouchstart" in window ? "click" : "hover",
    multiple: true,
    debug: false,
    functionReady: function (instance, helper) {
      if ($(instance.content()).find(".tooltip, .tooltip_sticky").length > 0) {
        initTooltip();
      }
    },
  });

  $(".tooltip_sticky").not(".tooltipstered").tooltipster({
    contentAsHTML: true,
    trigger: "ontouchstart" in window ? "click" : "hover",
    multiple: true,
    debug: false,
    interactive: true,
    functionReady: function (instance, helper) {
      if ($(instance.content()).find(".tooltip, .tooltip_sticky").length > 0) {
        initTooltip();
      }
    },
  });
}
