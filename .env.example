# Méthode recommandée : login HTTP sans navigateur
ASTROGAME_USERNAME=ton_pseudo
ASTROGAME_PASSWORD=ton_mot_de_passe


# Optionnel : cookies manuels (si tu préfères ne pas stocker le mot de passe)
# ASTROGAME_COOKIES=PHPSESSID=xxx; autre_cookie=yyy

# Niveau de logs : info | verbose | debug  (défaut : verbose)
# info    = seulement les messages importants (pas les étapes →)
# verbose = étapes intermédiaires incluses
# debug   = verbose + requêtes HTTP
ASTROGAME_LOG_LEVEL=info

# Raccourci équivalent à ASTROGAME_LOG_LEVEL=info :
# ASTROGAME_DEBUG=0

# Délai aléatoire entre requêtes galaxie (ms) — défaut 250–2000
# GALAXY_SCRAPE_DELAY_MIN_MS=250
# GALAXY_SCRAPE_DELAY_MAX_MS=2000
