{
  "name": "astrogame-api",
  "version": "0.1.0",
  "description": "Client Node pour automatiser les actions Astrogame (uni24)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "login": "node src/index.js login",
    "buildings": "node src/index.js buildings",
    "plan": "node src/index.js plan",
    "upgrade-next": "node src/index.js upgrade-next",
    "upgrade": "node src/index.js upgrade",
    "parse-local": "node src/index.js parse-local",
    "galaxy-scrape": "node src/index.js galaxy-scrape",
    "galaxy-merge": "node src/index.js galaxy-merge",
    "spy-reports": "node src/index.js spy-reports",
    "spy-send": "node src/index.js spy-send",
    "attack-loot": "node src/index.js attack-loot",
    "attacks-import": "node scripts/push-attacks-to-extension.mjs",
    "attacks-sync": "node scripts/write-attacks-chrome-storage.mjs",
    "attacks-today": "node scripts/export-attacks-today.mjs",
    "scan-empire": "node scripts/scan-empire-resources.mjs",
    "migrate-data": "node scripts/migrate-data-layout.mjs",
    "dev:kill": "node scripts/kill-ui-port.mjs",
    "predev": "node scripts/kill-ui-port.mjs",
    "dev": "concurrently --handle-input --kill-others-on-fail -n api,web -c blue,green \"node server/index.js\" \"npm run dev --prefix web\"",
    "dev:api": "node server/index.js",
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.2.0",
    "axios": "^1.9.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "classic-level": "^3.0.0",
    "concurrently": "^9.1.2"
  }
}
